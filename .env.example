FRONTEND_PORT=3000
FRONTEND_HTTPS_PORT=443
FRONTEND_DOMAIN=localhost
API_PORT=5000
MONGO_DB=resume_ai_app
JWT_SECRET=change-me-in-production
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# HTTPS / Let's Encrypt
# For production certificates, set FRONTEND_PORT=80, keep FRONTEND_HTTPS_PORT=443,
# point FRONTEND_DOMAIN at this server, then set CERTBOT_ENABLE=true and CERTBOT_EMAIL.
CERTBOT_ENABLE=false
CERTBOT_EMAIL=
CERTBOT_STAGING=false
CERTBOT_STARTUP_DELAY_SECONDS=10

# Email configuration
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_URL=
EMAIL_VERIFICATION_TOKEN_TTL_MINUTES=1440
EMAIL_VERIFICATION_URL=
