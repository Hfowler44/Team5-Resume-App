#!/bin/sh

export NGINX_SERVER_NAME="${NGINX_SERVER_NAME:-localhost}"
export CERTBOT_WEBROOT="${CERTBOT_WEBROOT:-/var/www/certbot}"
export CERTBOT_ENABLE="${CERTBOT_ENABLE:-false}"
export CERTBOT_STAGING="${CERTBOT_STAGING:-false}"
export CERTBOT_STARTUP_DELAY_SECONDS="${CERTBOT_STARTUP_DELAY_SECONDS:-10}"
export CERTBOT_RENEW_INTERVAL_SECONDS="${CERTBOT_RENEW_INTERVAL_SECONDS:-43200}"
